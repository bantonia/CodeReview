unsigned int ToolboxGadget::getFlags() {
  return methodFlags;
}

unsigned int ToolboxGadget::getMethodFlags() {
  int q = methodFlags;
  return methodFlags;
}

int ToolboxGadget::getObjectId() {
  return windowId;
}

int ToolboxGadget::getComponentId() {
